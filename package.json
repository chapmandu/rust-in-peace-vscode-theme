{
  "name": "rust-in-peace",
  "displayName": "Rust in Peace",
  "homepage": "https://github.com/chapmandu/rust-in-peace-vscode-theme",
  "description": "A dark theme inspired by the album art of Megadeth's 1990 metal masterpiece, Rust in Peace.",
  "version": "3.2.0",
  "engines": {
    "vscode": "^1.78.2"
  },
  "publisher": "chapmandu",
  "license": "MIT",
  "maintainers": [
    "Adam Chapman"
  ],
  "repository": {
    "type": "git",
    "name": "https://github.com/chapmandu/rust-in-peace-vscode-theme"
  },
  "bugs": {
    "type": "git",
    "name": "https://github.com/chapmandu/rust-in-peace-vscode-theme/issues"
  },
  "galleryBanner": {
    "color": "#0D166C",
    "theme": "dark"
  },
  "icon": "assets/logo.png",
  "categories": [
    "Themes"
  ],
  "keywords": [
    "Dark Theme",
    "Megadeth",
    "Rust in Peace",
    "Metal",
    "Hangar 18",
    "Holy Wars.. The Punishment Due",
    "Black",
    "Monokai",
    "Cobalt2"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Rust in Peace",
        "uiTheme": "vs-dark",
        "path": "./theme/rust-in-peace.json"
      },
      {
        "label": "Rust in Peace Hangar 18",
        "uiTheme": "vs-dark",
        "path": "./theme/rust-in-peace-hangar-18.json"
      },
      {
        "label": "Rust in Peace Polaris",
        "uiTheme": "vs-dark",
        "path": "./theme/rust-in-peace-polaris.json"
      },
      {
        "label": "Rust in Peace Dawn Patrol",
        "uiTheme": "vs",
        "path": "./theme/rust-in-peace-dawn-patrol.json"
      }
    ]
  },
  "scripts": {
    "build": "uv run python -m scripts.build",
    "build:themes": "uv run python -m scripts.build_themes",
    "lint": "uv run python -m scripts.lint",
    "test": "uv run pytest",
    "check": "uv run ruff check scripts tests && uv run ruff format --check scripts tests && uv run mypy && uv run vulture && npm run dupes && gitleaks git --redact --no-banner",
    "dupes": "jscpd scripts tests --threshold 3",
    "package": "vsce package -o ./bin/rust-in-peace.vsix",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "jscpd": "^4.0.5",
    "prettier": "^3.9.4"
  }
}
