{
  "name": "rust-in-peace",
  "displayName": "Rust in Peace",
  "homepage": "https://github.com/chapmandu/rust-in-peace-vscode-theme",
  "description": "A dark theme inspired by the album art of Megadeth's 1990 metal masterpiece, Rust in Peace.",
  "version": "3.1.1",
  "engines": {
    "vscode": "^1.78.2"
  },
  "publisher": "chapmandu",
  "license": "MIT",
  "maintainers": [
    "Adam Chapman"
  ],
  "repository": {
    "type": "git",
    "name": "https://github.com/chapmandu/rust-in-peace-vscode-theme"
  },
  "bugs": {
    "type": "git",
    "name": "https://github.com/chapmandu/rust-in-peace-vscode-theme/issues"
  },
  "galleryBanner": {
    "color": "#0D166C",
    "theme": "dark"
  },
  "icon": "assets/logo.png",
  "categories": [
    "Themes"
  ],
  "keywords": [
    "Dark Theme",
    "Megadeth",
    "Rust in Peace",
    "Metal",
    "Hangar 18",
    "Holy Wars.. The Punishment Due",
    "Black",
    "Monokai",
    "Cobalt2"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Rust in Peace",
        "uiTheme": "vs-dark",
        "path": "./theme/rust-in-peace.json"
      },
      {
        "label": "Rust in Peace Hangar 18",
        "uiTheme": "vs-dark",
        "path": "./theme/rust-in-peace-hangar-18.json"
      },
      {
        "label": "Rust in Peace Polaris",
        "uiTheme": "vs-dark",
        "path": "./theme/rust-in-peace-polaris.json"
      },
      {
        "label": "Rust in Peace Dawn Patrol",
        "uiTheme": "vs",
        "path": "./theme/rust-in-peace-dawn-patrol.json"
      }
    ]
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "build:themes": "tsx ./scripts/build-themes.ts",
    "lint": "tsx ./scripts/lint.ts",
    "eslint": "eslint scripts",
    "typecheck": "tsc --noEmit",
    "package": "vsce package -o ./bin/rust-in-peace.vsix",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.1.1",
    "@types/tinycolor2": "^1.4.6",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.6.0",
    "fallow": "^3.3.0",
    "js-yaml": "^5.2.1",
    "prettier": "^3.9.4",
    "tinycolor2": "^1.6.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
